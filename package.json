    "@payloadcms/richtext-lexical": "^3.77.0",
    "ai": "6.0.97",
    "graphql": "^16.12.0",
    "next": "16.1.6",
    "payload": "^3.77.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
