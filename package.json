{
  "name": "aisdkvercel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:evals": "vitest run --config vitest.config.evals.ts",
    "payload:importmap": "docker run --rm -v $(pwd):/app -v /app/node_modules -w /app node:22-slim bash -c 'npm install --legacy-peer-deps 2>/dev/null && npx payload generate:importmap'",
    "payload:generate-types": "docker run --rm -v $(pwd):/app -v /app/node_modules -w /app node:22-slim bash -c 'npm install --legacy-peer-deps 2>/dev/null && npx payload generate:types'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/react": "^3.0.99",
